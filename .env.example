# OpenAI API Key for phrase generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key (server-side only) — lets the Vapi webhook write transcripts
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Vapi voice agent (https://dashboard.vapi.ai)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_WEBHOOK_SECRET=any_random_string_match_in_vapi_dashboard
